<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    
    <!-- App metadata -->
    <AssemblyName>InternetSpeedMonitor</AssemblyName>
    <Product>Internet Speed Monitor</Product>
    <Description>Lightweight Windows 11 Internet Speed Monitor</Description>
    <Company>MeTariqul</Company>
    <Version>1.0.0</Version>
    <Copyright>Copyright 2024 MeTariqul</Copyright>
    
    <!-- App Icon -->
    <ApplicationIcon>ISM.ico</ApplicationIcon>
    
    <!-- Single file publish - Framework dependent (~1.3MB, requires .NET 8 runtime) -->
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>false</SelfContained>
    
    <!-- Suppress warning for WPF in single file -->
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
  </PropertyGroup>

  <ItemGroup>
    <!-- System tray icon package - lightweight -->
    <PackageReference Include="H.NotifyIcon.Wpf" Version="2.1.3" />
  </ItemGroup>

</Project>
