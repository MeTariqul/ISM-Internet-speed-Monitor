<Window x:Class="InternetSpeedMonitor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - Internet Speed Monitor"
        Width="420"
        Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="False"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Window.Resources>
        <!-- Modern ComboBox Style -->
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="6" CornerRadius="3" Background="#2A2A3E" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" CornerRadius="3" Background="#6366F1" HorizontalAlignment="Stretch"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="18" Height="18" Fill="#6366F1" Cursor="Hand">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="8" Color="#6366F1" Opacity="0.6"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="border" Background="#1A1A2E" CornerRadius="8" Padding="12,10" Margin="0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="checkBorder" Width="22" Height="22" CornerRadius="6" Background="#2A2A3E" BorderThickness="2" BorderBrush="#3A3A4E" Margin="0,0,12,0">
                                    <Path x:Name="checkMark" Data="M 3 8 L 7 12 L 14 4" Stroke="#6366F1" StrokeThickness="2" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBorder" Property="Background" Value="#6366F1"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkMark" Property="Stroke" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252538"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#2A2A3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                    <ToggleButton Grid.Column="1" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" Background="Transparent" BorderThickness="0">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <Path Data="M 0 0 L 4 4 L 8 0" Fill="#6B6B80" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" PlacementTarget="{Binding ElementName=border}">
                                <Border x:Name="DropDown" Background="#1A1A2E" BorderBrush="#2A2A3E" BorderThickness="1" CornerRadius="8" Margin="0,4,0,0">
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ComboBoxItem Style for dropdown items -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252538"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6366F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Modern Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6366F1" Offset="0"/>
                        <GradientStop Color="#4F46E5" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="28,12"/>
            <Setter Property="Margin" Value="8,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="10" Color="#6366F1" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C7FF7" Offset="0"/>
                                            <GradientStop Color="#6366F1" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#4F46E5" Offset="0"/>
                                            <GradientStop Color="#4338CA" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Padding" Value="28,12"/>
            <Setter Property="Margin" Value="8,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A3E"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252538"/>
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A1A2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Section Header Style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#6366F1"/>
            <Setter Property="Margin" Value="0,16,0,10"/>
        </Style>
        
        <!-- Label Style -->
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        
        <!-- Value Display Style -->
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6366F1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,8"/>
        </Style>
    </Window.Resources>
    
    <!-- Main Window Background with Gradient -->
    <Border CornerRadius="16" Margin="10">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F0F1A" Offset="0"/>
                <GradientStop Color="#1A1A2E" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="30" Color="#000000" Opacity="0.5"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="#16161F" CornerRadius="16,16,0,0" Padding="20,16">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Logo with Icon -->
                        <Border Width="48" Height="48" CornerRadius="12" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="12" Color="#6366F1" Opacity="0.4"/>
                            </Border.Effect>
                            <Grid>
                                <!-- Download Arrow -->
                                <Path Data="M 12 20 L 20 20 L 16 28 M 12 20 L 20 20 L 16 12" Stroke="White" StrokeThickness="2.5" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Internet Speed Monitor" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="by MeTariqul" FontSize="11" Foreground="#6366F1" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <!-- Close Button -->
                    <Button x:Name="CloseButton" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0" 
                            Click="CloseButton_Click" Cursor="Hand" Background="Transparent" BorderThickness="0" Width="32" Height="32">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="Transparent" CornerRadius="8">
                                    <Path x:Name="closeIcon" Data="M 8 8 L 18 18 M 18 8 L 8 18" Stroke="#6B6B80" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                        <Setter TargetName="closeIcon" Property="Stroke" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Settings Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Padding="20,10">
                <StackPanel>
                    <!-- Appearance Section -->
                    <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeader}"/>
                    
                    <TextBlock Text="Window Opacity" Style="{StaticResource LabelText}"/>
                    <Slider x:Name="TransparencySlider" Minimum="0.3" Maximum="1" Value="1" TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="TransparencySlider_ValueChanged" PreviewMouseWheel="Slider_PreviewMouseWheel"/>
                    <TextBlock Text="{Binding ElementName=TransparencySlider, Path=Value, StringFormat={}{0:P0}}" Style="{StaticResource ValueText}"/>
                    
                    <TextBlock Text="Background Blur Effect" Style="{StaticResource LabelText}"/>
                    <Slider x:Name="BackgroundOpacitySlider" Minimum="0.3" Maximum="1" Value="0.95" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="BackgroundOpacitySlider_ValueChanged" PreviewMouseWheel="Slider_PreviewMouseWheel"/>
                    <TextBlock Text="{Binding ElementName=BackgroundOpacitySlider, Path=Value, StringFormat={}{0:P0}}" Style="{StaticResource ValueText}"/>
                    
                    <TextBlock Text="Corner Roundness" Style="{StaticResource LabelText}"/>
                    <Slider x:Name="CornerRadiusSlider" Minimum="0" Maximum="20" Value="12" TickFrequency="2" IsSnapToTickEnabled="True" ValueChanged="CornerRadiusSlider_ValueChanged" PreviewMouseWheel="Slider_PreviewMouseWheel"/>
                    <TextBlock Text="{Binding ElementName=CornerRadiusSlider, Path=Value, StringFormat={}{0} px}" Style="{StaticResource ValueText}"/>
                    
                    <!-- Display Section -->
                    <TextBlock Text="DISPLAY" Style="{StaticResource SectionHeader}"/>
                    
                    <TextBlock Text="Speed Unit" Style="{StaticResource LabelText}"/>
                    <ComboBox x:Name="UnitComboBox" SelectionChanged="UnitComboBox_SelectionChanged">
                        <ComboBoxItem Content="Mbps (Bits)" Tag="true"/>
                        <ComboBoxItem Content="MB/s (Bytes)" Tag="false"/>
                    </ComboBox>
                    
                    <TextBlock Text="Refresh Rate" Style="{StaticResource LabelText}"/>
                    <ComboBox x:Name="RefreshComboBox" SelectionChanged="RefreshComboBox_SelectionChanged">
                        <ComboBoxItem Content="500 ms (Fast)" Tag="500"/>
                        <ComboBoxItem Content="1 second (Normal)" Tag="1000"/>
                        <ComboBoxItem Content="2 seconds (Slow)" Tag="2000"/>
                        <ComboBoxItem Content="5 seconds (Very Slow)" Tag="5000"/>
                    </ComboBox>
                    
                    <!-- Window Size Section -->
                    <TextBlock Text="WINDOW SIZE" Style="{StaticResource SectionHeader}"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Width" Style="{StaticResource LabelText}"/>
                            <Slider x:Name="WidthSlider" Minimum="180" Maximum="400" Value="280" TickFrequency="20" IsSnapToTickEnabled="True" ValueChanged="SizeSlider_ValueChanged" PreviewMouseWheel="Slider_PreviewMouseWheel"/>
                            <TextBlock Text="{Binding ElementName=WidthSlider, Path=Value, StringFormat={}{0}px}" Style="{StaticResource ValueText}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Height" Style="{StaticResource LabelText}"/>
                            <Slider x:Name="HeightSlider" Minimum="50" Maximum="150" Value="80" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="SizeSlider_ValueChanged" PreviewMouseWheel="Slider_PreviewMouseWheel"/>
                            <TextBlock Text="{Binding ElementName=HeightSlider, Path=Value, StringFormat={}{0}px}" Style="{StaticResource ValueText}"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Behavior Section -->
                    <TextBlock Text="BEHAVIOR" Style="{StaticResource SectionHeader}"/>
                    
                    <CheckBox x:Name="AlwaysOnTopCheckBox" Content="Always on Top" Checked="AlwaysOnTopCheckBox_Changed" Unchecked="AlwaysOnTopCheckBox_Changed"/>
                    <CheckBox x:Name="LockPositionCheckBox" Content="Lock Window Position" Checked="LockPositionCheckBox_Changed" Unchecked="LockPositionCheckBox_Changed"/>
                    <CheckBox x:Name="StartMinimizedCheckBox" Content="Start Minimized to Tray" Checked="StartMinimizedCheckBox_Changed" Unchecked="StartMinimizedCheckBox_Changed"/>
                    <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows" Checked="StartWithWindowsCheckBox_Changed" Unchecked="StartWithWindowsCheckBox_Changed"/>
                    <CheckBox x:Name="HideOnCloseCheckBox" Content="Hide to Tray on Close" Checked="HideOnCloseCheckBox_Changed" Unchecked="HideOnCloseCheckBox_Changed"/>
                    
                    <!-- Position Section -->
                    <TextBlock Text="POSITION" Style="{StaticResource SectionHeader}"/>
                    
                    <Button Content="Reset Window Position" Click="ResetPosition_Click" Style="{StaticResource SecondaryButton}" Padding="16,10" Margin="0,4"/>
                    
                    <!-- Credit Section -->
                    <TextBlock Text="CREDITS" Style="{StaticResource SectionHeader}"/>
                    
                    <Border Background="#1A1A2E" CornerRadius="10" Padding="16,12" Margin="0,4">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Internet Speed Monitor" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Version 1.0.0" FontSize="11" Foreground="#6B6B80" HorizontalAlignment="Center" Margin="0,4,0,8"/>
                            <TextBlock Text="Developed by" FontSize="11" Foreground="#6B6B80" HorizontalAlignment="Center"/>
                            <TextBlock Text="MeTariqul" FontSize="13" FontWeight="SemiBold" Foreground="#6366F1" HorizontalAlignment="Center" Margin="0,2,0,10"/>
                            <TextBlock HorizontalAlignment="Center" Foreground="#8B8B9A" FontSize="11" Cursor="Hand">
                                <Hyperlink NavigateUri="https://github.com/MeTariqul" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#6366F1">
                                    <Run Text="Visit GitHub Profile"/>
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Bottom Buttons -->
            <Border Grid.Row="2" Background="#16161F" CornerRadius="0,0,16,16" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="Cancel" Click="Cancel_Click" Style="{StaticResource SecondaryButton}"/>
                    <Button Grid.Column="1" Content="Save" Click="SaveClose_Click" Style="{StaticResource PrimaryButton}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
