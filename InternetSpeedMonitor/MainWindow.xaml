<Window x:Class="InternetSpeedMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        Title="Internet Speed Monitor" 
        Width="280" 
        Height="80"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Left="10"
        Top="10"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        SizeChanged="Window_SizeChanged"
        LocationChanged="Window_LocationChanged">
    
    <Window.Resources>
        <LinearGradientBrush x:Key="DarkBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#CC1E1E2E" Offset="0"/>
            <GradientStop Color="#E02D2D44" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="LightBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0"/>
            <GradientStop Color="#F0F0F0" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>
    
    <Grid>
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Internet Speed Monitor"
                        TrayLeftMouseDoubleClick="TrayIcon_TrayLeftMouseDoubleClick"
                        Visibility="Visible">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show/Hide" Click="ShowHideMenuItem_Click"/>
                    <MenuItem Header="Settings" Click="SettingsMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="ExitMenuItem_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
        
        <Border x:Name="MainBorderElement"
                Background="{StaticResource DarkBackgroundBrush}" 
                CornerRadius="12" 
                BorderBrush="#3D3D5C" 
                BorderThickness="1"
                Padding="12,8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock x:Name="DownloadArrowText" Text="↓" Foreground="#4ADE80" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
                
                <TextBlock Grid.Column="1" 
                          x:Name="DownloadSpeedText"
                          Text="0.0 KB/s" 
                          Foreground="#4ADE80" 
                          FontSize="16" 
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          Margin="4,0,12,0"/>
                
                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock x:Name="UploadArrowText" Text="↑" Foreground="#F472B6" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
                
                <TextBlock Grid.Column="3" 
                          x:Name="UploadSpeedText"
                          Text="0.0 KB/s" 
                          Foreground="#F472B6" 
                          FontSize="16" 
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
